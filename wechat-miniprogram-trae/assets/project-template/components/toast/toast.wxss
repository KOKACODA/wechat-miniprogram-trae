.toast-wrap { position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 9999; opacity: 0; transition: opacity 0.3s; pointer-events: none; }
.toast-wrap.show { opacity: 1; }
.toast-content { background: rgba(0,0,0,0.75); color: #fff; padding: 20rpx 40rpx; border-radius: 12rpx; font-size: 28rpx; }
